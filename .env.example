CMAPSS_DATA_DIR=data/
TCN_RESULTS_DIR=artifacts/tcn/results/
TCN_FIGURES_DIR=artifacts/tcn/figures/
TCN_CHECKPOINT_DIR=artifacts/tcn/checkpoints/
TCN_LOGS_DIR=artifacts/tcn/logs/

# Optional: force the hybrid stage to use a specific checkpoint instead of
# auto-discovering best_model_<experiment_name>.pth from TCN_CHECKPOINT_DIR.
TCN_CHECKPOINT=

# Optional: local transformers-readable TimeOmni model directory.
TIMEOMNI_MODEL_DIR=

# Optional: override hybrid output directory.
HYBRID_OUTPUT_DIR=artifacts/hybrid/fd001_demo/
